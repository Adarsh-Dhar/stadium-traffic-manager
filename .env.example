# Copy this file to .env and fill in real secrets. Do NOT commit real keys.

# ── Gemini AI ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Dynatrace (optional observability integration) ───────────────────────
DYNATRACE_ENV_ID=wdp79156
DYNATRACE_API_TOKEN=your_dynatrace_api_token_here
DYNATRACE_CLUSTER_URL=https://wdp79156.apps.dynatrace.com
DT_ENVIRONMENT=https://wdp79156.apps.dynatrace.com
DT_PLATFORM_TOKEN=your_dynatrace_api_token_here

# ── API Server ─────────────────────────────────────────────────────────────
PORT=5000
AI_AGENT_API_BASE=http://localhost:5000/api/fifa

# ── RPS Prediction Agent ───────────────────────────────────────────────────
AGENT_CHECK_INTERVAL=60000
AI_AGENT_DRY_RUN=false

# ── Redis (ticketing velocity) ────────────────────────────────────────────
# Spin up with:  docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# ── PostgreSQL (historical baselines) ───────────────────────────────────────
# Spin up with:  docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16-alpine
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/stadium

# Game type for this event (controls which historical row is loaded)
# Values: low_stakes_game | regular_game | playoff_game
GAME_TYPE=regular_game

# ── Stadium GPS (for Open-Meteo weather) ──────────────────────────────────
# MetLife Stadium, East Rutherford NJ (FIFA WC 2026 venue)
STADIUM_LAT=40.8128
STADIUM_LON=-74.0742

# ── Transit.land (optional — mock used if not set) ────────────────────────
# Get a free key at https://www.transit.land/
TRANSITLAND_KEY=
TRANSIT_STOP_ID=s-dr5rjy-pennstation

# ── TomTom (optional — mock used if not set) ──────────────────────────────
# Free tier: 2500 req/day  https://developer.tomtom.com/
TOMTOM_API_KEY=
ROAD_LAT=40.8128
ROAD_LON=-74.0742

# ── Football Data API (World Cup matches/standings) ───────────────────────
# Free tier available at https://www.football-data.org/
# Without this key, the dashboard shows static fixture data only.
FOOTBALL_DATA_API_KEY=
