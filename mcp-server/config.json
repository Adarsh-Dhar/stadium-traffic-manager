{
  "mcp_server": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@dynatrace-oss/dynatrace-mcp-server@latest"],
    "env": {
      "DT_ENVIRONMENT": "${DYNATRACE_CLUSTER_URL}",
      "DT_PLATFORM_TOKEN": "${DYNATRACE_API_TOKEN}"
    }
  },
  "tools": [
    "get_problems",
    "get_entities",
    "execute_dql"
  ]
}
